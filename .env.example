# Copy this file to .env on your server.
# Do not commit .env. It contains deployer-owned secrets.

# AI model configuration
AI_ANALYSIS_ENABLED=true
AI_API_BASE=
AI_API_KEY=
AI_MODEL=

# Notification channels
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
WEWORK_WEBHOOK_URL=
WEWORK_MSG_TYPE=markdown
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_TO=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=
NTFY_SERVER_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
BARK_URL=
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_TEMPLATE=

# S3-compatible remote storage
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# Runtime behavior
CRON_SCHEDULE=*/30 * * * *
RUN_MODE=cron
IMMEDIATE_RUN=true
ENABLE_WEBSERVER=true
WEBSERVER_PORT=8080
